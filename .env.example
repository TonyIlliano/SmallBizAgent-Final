# ===========================================
# SmallBizAgent Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Database Configuration
# ===========================================
# Local PostgreSQL (Docker):
# DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/smallbiz
#
# Neon Serverless (Production):
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/smallbiz

# ===========================================
# Session & Security
# ===========================================
# REQUIRED in production - generate with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-change-this-in-production

# REQUIRED in production - encrypts POS credentials, API keys stored in DB
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=your_64_char_hex_key

# ===========================================
# Base URL (REQUIRED in production)
# ===========================================
# Your publicly accessible URL for webhooks, password reset links, invoice sharing.
# Both APP_URL and BASE_URL are accepted — set at least one.
# Examples:
#   - Local dev with ngrok: https://abc123.ngrok.io
#   - Railway: https://your-app.railway.app
#   - Render: https://your-app.onrender.com
BASE_URL=https://your-public-url.com
# APP_URL=https://your-public-url.com

# ===========================================
# Twilio Configuration (SMS & Voice)
# ===========================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# ===========================================
# Vapi.ai Configuration (AI Voice Receptionist)
# ===========================================
VAPI_API_KEY=your_vapi_api_key
# Webhook secret for validating Vapi webhook requests (RECOMMENDED for production)
# VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret

# ===========================================
# Stripe Configuration (Payments & Billing)
# ===========================================
# Use test keys for development (sk_test_*, pk_test_*)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
# Webhook secret from Stripe dashboard: Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ===========================================
# OpenAI (AI Agents - Review Response, Auto-Refine, Conversational Booking)
# ===========================================
# OPENAI_API_KEY=your_openai_api_key

# ===========================================
# Optional: Google Calendar Integration
# ===========================================
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===========================================
# Optional: QuickBooks Integration
# ===========================================
# QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
# QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret

# ===========================================
# Optional: AWS Configuration (S3 file storage, Lex AI)
# ===========================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# S3_MEDIA_BUCKET=your-s3-bucket-name

# ===========================================
# Optional: Email Providers
# ===========================================
# SendGrid:
# SENDGRID_API_KEY=your_sendgrid_api_key
#
# Resend (alternative):
# RESEND_API_KEY=your_resend_api_key
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ===========================================
# Optional: Cloudflare Turnstile (Bot Protection)
# ===========================================
# TURNSTILE_SECRET_KEY=your_turnstile_secret_key
# VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# ===========================================
# Optional: Error Tracking
# ===========================================
# SENTRY_DSN=your_sentry_dsn

# ===========================================
# Environment Mode
# ===========================================
NODE_ENV=development
