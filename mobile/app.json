{
  "expo": {
    "name": "SmallBizAgent",
    "slug": "smallbizagent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#663399"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.smallbizagent.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#663399"
      },
      "package": "ai.smallbizagent.app"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite"
    ]
  }
}
